<!DOCTYPE html>
<html>
<body>

<script>
const contarLetraA = (texto) => {
    let contador = 0;

    for (let i = 0; i < texto.length; i++) {
        if (texto[i].toLowerCase() === 'a') {
            contador++;
        }
    }

    return contador;
};

let texto = prompt("Ingrese un texto:");
let resultado = contarLetraA(texto);

console.log("La letra 'a' aparece " + resultado + " veces");
</script>

</body>
</html>